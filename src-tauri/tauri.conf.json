{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zest Game",
  "mainBinaryName": "zest-game",
  "version": "0.0.1",
  "identifier": "zest.author.name",
  "app": {
    "windows": [
      {
        "title": "Zest Game",
        "width": 800,
        "height": 480,
        "minWidth": 400,
        "minHeight": 240,
        "resizable": false,
        "fullscreen": false,
        "backgroundThrottling": "disabled"
      }
    ],
    "withGlobalTauri": true
  },
  "bundle": {
    "copyright": "Author",
    "targets": ["app", "deb", "appimage"],
    "active": true,
    "category": "Game",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "build": { "frontendDist": "../web" }
}
